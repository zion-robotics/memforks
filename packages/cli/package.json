{
  "name": "@memfork/cli",
  "version": "0.1.11",
  "description": "MemForks CLI — init, commit, recall, merge, install plugins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memforks-dev/memforks.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/memforks-dev/memforks#readme",
  "bugs": {
    "url": "https://github.com/memforks-dev/memforks/issues"
  },
  "type": "module",
  "bin": {
