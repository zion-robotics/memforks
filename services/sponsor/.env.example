# ── Required ───────────────────────────────────────────────────────────────────

# The sponsor wallet's private key. This wallet pays all gas fees.
# Generate with: sui keytool generate ed25519
# Fund it with enough SUI for your expected volume.
# Format: bech32 suiprivkey1... or 64-char hex
SPONSOR_PRIVATE_KEY=suiprivkey1...

# ── Network ────────────────────────────────────────────────────────────────────

# "mainnet" | "testnet" | "devnet" | "localnet"
SUI_NETWORK=mainnet

# Optional: override the RPC endpoint
# SUI_RPC_URL=https://fullnode.mainnet.sui.io

# ── MemForks ───────────────────────────────────────────────────────────────────

# The MemForks Move package ID on the target network.
# Used to validate that only MemForks entry functions are being sponsored.
MEMFORK_PACKAGE_ID=0xc13cc014fb8084b3468f6e5ffdc272e64ef35b7a912332eba7a0d44dd66b3121

# ── Rate limiting ──────────────────────────────────────────────────────────────

# Per-address limits (per Sui sender address).
RATE_MAX_PER_WIN=10
RATE_WINDOW_MS=60000

# Per-IP limits (stops Sybil attacks — many addresses from one host).
RATE_IP_MAX_PER_WIN=40
RATE_IP_WINDOW_MS=60000

# Global daily cap — hard ceiling regardless of how many addresses/IPs are used.
# At 5M MIST per tx, 5000 tx/day = ~0.025 SUI/day maximum spend.
RATE_DAILY_MAX_TX=5000

# init_tree strict cap — how many sponsored tree-creations allowed per IP per day.
# Default: 1. A real developer only needs one tree. Raise this for hackathons/events.
RATE_INIT_TREE_PER_IP_DAY=1

# ── Gas ────────────────────────────────────────────────────────────────────────

# Gas budget per transaction in MIST (1 SUI = 1_000_000_000 MIST).
# MemForks branch/merge ops typically cost 2–5M MIST (~$0.001 at launch price).
# Default: 10_000_000 (0.01 SUI) — comfortable headroom.
SPONSOR_GAS_BUDGET=90000000

# ── Drip (mainnet onboarding) ──────────────────────────────────────────────────
# Sends a small SUI amount to fresh addresses so they can pay gas for the two
# MemWal bootstrap calls (createAccount + addDelegateKey) during `memfork init`.

# Amount to send per drip in MIST (default: 20_000_000 = 0.02 SUI).
# Must cover createAccount + addDelegateKey gas costs (~2–5M MIST each).
DRIP_AMOUNT_MIST=20000000

# Addresses with at least this balance (in MIST) are skipped (default: 5_000_000 = 0.005 SUI).
DRIP_MIN_BALANCE_MIST=5000000

# Max drips per originating IP per 24 h (default: 1).
DRIP_IP_DAILY_MAX=1

# ── Server ─────────────────────────────────────────────────────────────────────

PORT=3100
