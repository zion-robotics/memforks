# ── Runtime configuration ────────────────────────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local.

# Sui network
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
MEMFORKS_PACKAGE_ID=0x<deployed_package_id>
MEMFORKS_TREE_ID=0x<tree_object_id>

# Finalizer — must have MERGE permission on all managed branches.
FINALIZER_PRIVATE_KEY=suiprivkey1...

# ── Jury workers (add more by incrementing N) ──────────────────────────────
# Each judge needs a funded Sui wallet + (optionally) an LLM for evaluation.
JUDGE_0_KEY=suiprivkey1...
JUDGE_0_LLM_PROVIDER=openai
JUDGE_0_LLM_MODEL=gpt-4o
JUDGE_0_LLM_API_KEY=sk-...

JUDGE_1_KEY=suiprivkey1...
JUDGE_1_LLM_PROVIDER=anthropic
JUDGE_1_LLM_MODEL=claude-opus-4-8
JUDGE_1_LLM_API_KEY=sk-ant-...

JUDGE_2_KEY=suiprivkey1...
JUDGE_2_LLM_PROVIDER=openai
JUDGE_2_LLM_MODEL=gpt-4o-mini
JUDGE_2_LLM_API_KEY=sk-...

# ── LLM runner (produces the resolved payload) ─────────────────────────────
LLM_RUNNER_KEY=suiprivkey1...
LLM_RUNNER_PROVIDER=openai
LLM_RUNNER_MODEL=gpt-4o
LLM_RUNNER_API_KEY=sk-...

# ── MemWal (for reading branch content and storing resolved blobs) ──────────
MEMFORKS_MEMWAL_KEY=<64-char-hex-delegate-key>
MEMWAL_ACCOUNT_ID=0x<memwal_account_object_id>
MEMWAL_SERVER_URL=https://relayer.staging.memwal.ai
