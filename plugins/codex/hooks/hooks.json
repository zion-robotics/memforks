{
  "description": "MemForks hooks — branch-synced recall on session start, auto-commit on turn end",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 20,
            "statusMessage": "Loading MemForks memory for this branch"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/user-prompt-submit.sh\"",
            "timeout": 10,
            "statusMessage": "Checking MemForks recall"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/stop.sh\"",
            "timeout": 120,
            "statusMessage": "Committing learned facts to MemForks"
          }
        ]
      }
    ]
  }
}
