# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional: override model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o

# ── MemForks ──────────────────────────────────────────────────────────────────
MEMFORK_TREE_ID=0x...
MEMFORK_PRIVATE_KEY=suiprivkey1...
MEMFORK_NETWORK=testnet

# ── MemWal ────────────────────────────────────────────────────────────────────
MEMFORK_MEMWAL_ACCOUNT=0x...
MEMFORK_MEMWAL_KEY=...
MEMFORK_RELAYER_URL=https://relayer-staging.memory.walrus.xyz

# ── Gas sponsorship (optional, mainnet only) ──────────────────────────────────
# Removes gas cost for all on-chain operations (branch, proposeMerge, etc.)
# Only works with MEMFORK_NETWORK=mainnet. Do not set on testnet.
MEMFORK_SPONSOR_URL=https://memforks-sponsor-production.up.railway.app/sponsor

# ── On-chain merge ceremony (optional) ────────────────────────────────────────
# Set to enable full proposeMerge → resolver → finalizeMerge flow.
# Leave unset to use simple merge (recall from worker branches → commit to supervisor).
# MEMFORK_RESOLVER_ID=0x...

# ── Web search (optional) ─────────────────────────────────────────────────────
# If set, workers use Tavily for real web search. Otherwise falls back to LLM knowledge.
# TAVILY_API_KEY=tvly-...
