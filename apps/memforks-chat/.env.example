# OpenAI — required for chat
OPENAI_API_KEY=sk-...

# MemForks — run `memfork init --quick` (mainnet, gas sponsored) then `memfork doctor --env`
MEMFORK_TREE_ID=0x...
MEMFORK_PRIVATE_KEY=suiprivkey1...
MEMFORK_MEMWAL_ACCOUNT=0x...
MEMFORK_MEMWAL_KEY=...
MEMFORK_NETWORK=mainnet
# Relayer URL — must match the network above.
# mainnet: https://relayer.memory.walrus.xyz
# testnet: https://relayer-staging.memory.walrus.xyz
MEMFORK_RELAYER_URL=https://relayer.memory.walrus.xyz
